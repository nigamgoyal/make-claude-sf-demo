# Copy to .env and fill in your values.
# .env is gitignored — never commit it.

# Make.com API token. Generate at https://www.make.com/en/profile → API
# Minimum scopes: scenarios:read, scenarios:run, scenarios:write
MAKE_API_TOKEN=""

# Make.com zone. Check your URL bar — e.g., us2.make.com, eu1.make.com
MAKE_ZONE="us2.make.com"

# Team ID — the number after /team/ or in URLs like make.com/2172456/scenarios
MAKE_TEAM_ID=""

# Scenario ID — the number after /scenarios/
MAKE_SCENARIO_ID=""
